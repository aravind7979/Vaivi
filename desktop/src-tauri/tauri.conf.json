{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vaivi",
  "version": "0.1.0",
  "identifier": "com.vaivi.app",
  "build": {
    "frontendDist": "../../website"
  },
  "app": {
    "windows": [
      {
        "title": "Vaivi",
        "width": 1000,
        "height": 700,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}